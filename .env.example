# Local configuration: copy to `.env` in this directory. Do not commit `.env`.

DJANGO_SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=*

# Postgres URL. Omit this line (or leave empty) to use SQLite (db.sqlite3).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Optional: `seed_profiles` batch size on Postgres (defaults to 250 if unset).
SEED_POSTGRES_BATCH=250

# --- GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
BACKEND_PUBLIC_URL=http://localhost:8000
WEB_PORTAL_ORIGIN=http://localhost:5173
INSIGHTA_CLI_OAUTH_REDIRECT=http://127.0.0.1:8765/callback
JWT_SIGNING_KEY=
