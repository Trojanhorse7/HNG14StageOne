# Local configuration: copy to `.env` in this directory. Do not commit `.env`.

DJANGO_SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=*

# Postgres URL. Omit this line (or leave empty) to use SQLite (db.sqlite3).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Optional: `seed_profiles` batch size on Postgres (defaults to 250 if unset).
SEED_POSTGRES_BATCH=250

# --- GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
BACKEND_PUBLIC_URL=http://localhost:8000
WEB_PORTAL_ORIGIN=http://localhost:5173
# Optional: comma-separated extra browser origins allowed for CORS + CSRF (credentials).
# CORS_ALLOW_ALL_ORIGINS is off; portal and common Vite URLs are included by default.
# CORS_EXTRA_ORIGINS=https://preview.example.com
# GitHub OAuth App: register ONLY this callback (browser + CLI share it):
#   {BACKEND_PUBLIC_URL}/auth/github/callback
# After GitHub, the API sends CLI users to this loopback (must match insighta-cli --redirect-uri):
INSIGHTA_CLI_OAUTH_REDIRECT=http://127.0.0.1:8765/callback
JWT_SIGNING_KEY=

# Optional JWT lifetimes (seconds); see README / config.settings
# ACCESS_TOKEN_LIFETIME_SECONDS=180
# REFRESH_TOKEN_LIFETIME_SECONDS=300
