# Copy to .env. Do not commit .env.

DJANGO_SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=*

# Omit or empty → SQLite. Else Postgres.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# seed_profiles batch on Postgres (default 250).
SEED_POSTGRES_BATCH=250

# Portal GitHub OAuth — callback: {BACKEND_PUBLIC_URL}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
BACKEND_PUBLIC_URL=http://localhost:8000
WEB_PORTAL_ORIGIN=http://localhost:5173

# CLI GitHub OAuth — callback must equal INSIGHTA_CLI_OAUTH_REDIRECT (loopback).
GITHUB_CLI_CLIENT_ID=
GITHUB_CLI_CLIENT_SECRET=
INSIGHTA_CLI_OAUTH_REDIRECT=http://127.0.0.1:8765/callback

# Extra CORS/CSRF origins (comma-separated). Optional.
# CORS_EXTRA_ORIGINS=https://preview.example.com

JWT_SIGNING_KEY=

# --- Optional: automated grader (browser test_code). Keep disabled in production.
INSIGHTA_ENABLE_TEST_OAUTH_CODE=true
INSIGHTA_TEST_OAUTH_CODE=test_code
GRADER_ADMIN_USERNAME=mygithublogin

# ACCESS_TOKEN_LIFETIME_SECONDS=180
# REFRESH_TOKEN_LIFETIME_SECONDS=300
